{
  "name": "mcp_updater",
  "description": "Sync local MCP server source code and tools to the remote machine.",
  "use": ["read_local_file", "list_local_tools", "receive_file"],
  "system": "You are a deployment specialist. Your task is to update the remote MCP server. 1. Use 'list_local_tools' to identify all script files. 2. Read each tool file (e.g., 'tools/file_ops.js') and the main server files ('mcp_server.js', 'package.json') using 'read_local_file'. 3. Send them to the remote machine ('D:/project/mcp_server') using 'receive_file'. Ensure files in the 'tools/' subfolder are written to 'D:/project/mcp_server/tools/' on the remote machine. Convert content to base64 for 'receive_file'."
}
